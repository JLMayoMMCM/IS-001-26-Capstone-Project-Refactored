# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ─────────────────────────────────────────────────────────
fluxtrack/node_modules
fluxtrack/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Stray root-level npm install (not part of any workspace; Next.js otherwise
# infers the wrong workspace root). If you intentionally introduce a root-level
# workspace later, remove these three lines.
/node_modules
/package.json
/package-lock.json

# ─── Testing ──────────────────────────────────────────────────────────────
fluxtrack/coverage

# ─── Next.js ──────────────────────────────────────────────────────────────
fluxtrack/.next/
fluxtrack/out/

# ─── Production builds ────────────────────────────────────────────────────
fluxtrack/build

# ─── OS / editor ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.log
.vscode/
.idea/

# ─── Debug ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Env files (secrets) — keep .example committed ────────────────────────
fluxtrack/.env*
replication/.env*
.env*
!**/.env*.example

# ─── Vercel ───────────────────────────────────────────────────────────────
fluxtrack/.vercel
.vercel

# ─── TypeScript / build caches ────────────────────────────────────────────
**/*.tsbuildinfo
fluxtrack/next-env.d.ts

# ─── Supabase CLI local state (not the replication/ SQL + functions!) ─────
supabase/.branches
supabase/.temp
**/.supabase/

# ─── Supabase CLI replication state (SQL + functions) ──────────────────────
/replication